{
  "name": "nimbus",
  "version": "1.2.13",
  "description": "Nimbus Pomodoro Timer desktop client for macOS and Windows.",
  "private": true,
  "author": "Josh Johnson",
  "main": "desktop/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "check": "node --check desktop/main.js && node --check desktop/preload.js && node --check scripts/generate-icons.js",
    "icons": "node scripts/generate-icons.js",
    "deploy:web": "firebase deploy --only hosting",
    "package": "electron-builder --dir --publish never",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "release:mac": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.murderszn.nimbus",
    "productName": "Nimbus",
    "copyright": "Copyright © 2026 Josh Johnson",
    "asar": true,
    "files": [
      "pomodoro-cloud-v2.html",
      "desktop/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "murderszn",
        "repo": "nimbus",
        "releaseType": "release"
      }
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "identity": "-",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
